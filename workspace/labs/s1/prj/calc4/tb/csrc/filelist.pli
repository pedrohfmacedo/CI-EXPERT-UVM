PLI_STUB_OBJS_OBJ0=_vcs_pli_stub_.o
PLI_STUB_OBJS_SRC0=_vcs_pli_stub_.c
PLI_STUB_OBJS += $(PLI_STUB_OBJS_OBJ0)
$(PLI_STUB_OBJS_OBJ0): $(PLI_STUB_OBJS_SRC0)
	@$(CC) -I/Tools/synopsys/vcs/X-2025.06-SP2/include  -pipe -fPIC -I/Tools/synopsys/vcs/X-2025.06-SP2/include     -fno-strict-aliasing -fno-optimize-sibling-calls  -fPIC -c -o $(PLI_STUB_OBJS_OBJ0) $(PLI_STUB_OBJS_SRC0)
	@strip -g $(PLI_STUB_OBJS_OBJ0)
